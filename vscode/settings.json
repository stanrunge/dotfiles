{
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },

  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features",
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnType": true,
  },
  "[xml]": {
    "editor.defaultFormatter": "redhat.vscode-xml",
  },
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.defaultFormatter": "redhat.vscode-yaml",
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
  },
  "[svelte]": {
    "editor.defaultFormatter": "svelte.svelte-vscode",
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[plaintext]": {
    "editor.unicodeHighlight.ambiguousCharacters": false,
    "editor.unicodeHighlight.invisibleCharacters": false,
  },

  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,

  "editor.accessibilitySupport": "off",
  "editor.fontFamily": "JetBrainsMono Nerd Font, Geist Mono, Jetbrains Mono, Consolas, 'Courier New', monospace",
  "editor.fontLigatures": false,
  "editor.fontWeight": "600",
  "editor.hover.enabled": "on",
  "editor.inlineSuggest.enabled": true,
  "editor.suggestSelection": "first",
  "editor.unicodeHighlight.nonBasicASCII": false,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "files.exclude": {
    "**/.classpath": true,
    "**/.factorypath": true,
    "**/.project": true,
    "**/.settings": true,
  },
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": false,
    "scminput": false,
    "css": false,
    "java": true,
    "javascript": true,
    "yaml": true,
  },
  "githubPullRequests.fileListLayout": "tree",
  "githubPullRequests.pullBranch": "never",
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "liveServer.settings.donotShowInfoMsg": true,
  "lldb.launch.expressions": "native",
  "lldb.library": "/Applications/Xcode.app/Contents/SharedFrameworks/LLDB.framework/Versions/A/LLDB",
  "notebook.formatOnSave.enabled": true,
  "python.pythonPath": "/usr/local/bin/python3",
  "react-native-tools.showUserTips": false,
  "redhat.telemetry.enabled": true,
  "remote.SSH.remotePlatform": {
    "192.168.50.65": "linux",
    "192.168.50.7": "linux",
    "stan-server": "linux",
    "stan-macbook.local": "macOS",
  },
  "security.workspace.trust.untrustedFiles": "open",
  "svelte.enable-ts-plugin": true,
  "vscode-edge-devtools.mirrorEdits": true,
  "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
  "workbench.startupEditor": "none",
  "git.openRepositoryInParentFolders": "always",
  "editor.renderWhitespace": "none",
  "git.ignoreRebaseWarning": true,

  "diffEditor.ignoreTrimWhitespace": false,
  "diffEditor.renderSideBySide": true,
  "workbench.iconTheme": "vscode-icons",

  "emmet.triggerExpansionOnTab": true,
  "emmet.includeLanguages": {
    "javascript": "javascriptreact",
  },
  "editor.formatOnType": false,
  "editor.formatOnSave": true,
  "editor.stickyScroll.enabled": true,
  "editor.stickyScroll.maxLineCount": 5,
  "editor.guides.bracketPairs": true,
  "editor.glyphMargin": false,
  "jupyter.askForKernelRestart": false,

  "go.toolsManagement.autoUpdate": true,
  "cmake.configureOnOpen": true,
  "explorer.confirmPasteNative": false,
  "qiskit-vscode.config.firstRun": false,
  "qiskit-vscode.ibmq.token": null,
  "qiskit-vscode.ibmq.hub": "",
  "qiskit-vscode.ibmq.url": "",
  "qiskit-vscode.ibmq.group": "",
  "qiskit-vscode.ibmq.project": "",
  "cmake.showOptionsMovedNotification": false,
  "editor.unicodeHighlight.invisibleCharacters": false,
  "editor.unicodeHighlight.ambiguousCharacters": false,
  "github.copilot.editor.enableAutoCompletions": true,
  "update.showReleaseNotes": false,
  "githubIssues.queries": [
    {
      "label": "My Issues",
      "query": "is:open assignee:${user} repo:${owner}/${repository}",
      "groupBy": ["milestone"],
    },
    {
      "label": "Created Issues",
      "query": "author:${user} state:open repo:${owner}/${repository} sort:created-desc",
    },
    {
      "label": "Recent Issues",
      "query": "state:open repo:${owner}/${repository} sort:updated-desc",
    },
  ],
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.enableImages": true,
  "terminal.integrated.tabs.description": "${task}${separator}${local}${separator}${cwd}",
  "terminal.integrated.tabs.location": "left",
  "terminal.integrated.experimentalInlineChat": true,
  "terminal.integrated.inheritEnv": false,
  "terminal.integrated.defaultProfile.linux": "zsh",
  "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font",
  "terminal.integrated.fontSize": 15,
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.allowedLinkSchemes": [
    "file",
    "http",
    "https",
    "mailto",
    "vscode",
    "vscode-insiders",
    "docker-desktop",
  ],
  "window.restoreFullscreen": true,
  "makefile.configureOnOpen": true,
  "vim.easymotion": true,
  "lldb.suppressUpdateNotifications": true,
  "chat.editing.alwaysSaveWithGeneratedChanges": true,
  "[php]": {
    "editor.defaultFormatter": "bmewburn.vscode-intelephense-client",
  },

  "zenMode.fullScreen": false,
  "githubPullRequests.remotes": ["origin", "upstream", "github"],
  "files.associations": {
    "*.svelte": "svelte",
  },
  "workbench.editor.labelFormat": "short",
  "vim.disableExtension": true,
  "debug.javascript.autoAttachSmartPattern": [
    "${workspaceFolder}/**",
    "**/$KNOWN_TOOLS$/**",
  ],
  "notebook.lineNumbers": "on",
  "editor.minimap.enabled": true,
  "editor.minimap.scale": 1,
  "editor.minimap.renderCharacters": false,
  "editor.minimap.maxColumn": 100,

  "workbench.sideBar.location": "right",
  "playwright.env": {
    "META_WEBHOOK_VERIFY_TOKEN": "DrTXLhg7qvNBxK2jnwZKmpYld84tR731",
  },
  "githubPullRequests.createOnPublishBranch": "never",
  "vitest.debugExclude": ["<node_internals>/**", "**/node_modules/**"],
  "inlineChat.enableV2": true,
  "inlineChat.accessibleDiffView": "on",
  "workbench.editor.tabSizing": "shrink",
  "python.analysis.typeCheckingMode": "standard",
  "errorLens.enabledDiagnosticLevels": ["error", "warning"],

  "remote.autoForwardPortsSource": "hybrid",
  "workbench.panel.opensMaximized": "always",
  "editor.folding": true,
  "editor.foldingImportsByDefault": true,
  "editor.foldingStrategy": "auto",
  "editor.showFoldingControls": "always",
  "chat.mcp.serverSampling": {
    "Global in Code: github": {
      "allowedModels": ["github.copilot-chat/gpt-4.1"],
    },
  },

  "discord.suppressNotifications": true,

  "js/ts.inlayHints.functionLikeReturnTypes.enabled": true,
  "js/ts.inlayHints.parameterNames.enabled": "all",
  "js/ts.inlayHints.parameterTypes.enabled": true,
  "js/ts.inlayHints.propertyDeclarationTypes.enabled": true,
  "js/ts.inlayHints.variableTypes.enabled": true,
  "js/ts.suggest.autoImports": true,
  "js/ts.preferences.importModuleSpecifier": "relative",
  "js/ts.tsserver.experimental.enableProjectDiagnostics": true,
  "js/ts.inlayHints.enumMemberValues.enabled": true,
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },

  "editor.inlineSuggest.showToolbar": "always",

  "github.copilot.nextEditSuggestions.enabled": true,
  "github.copilot.chat.codesearch.enabled": true,
  "github.copilot.chat.agent.thinkingTool": true,
  "github.copilot.chat.editor.temporalContext.enabled": true,
  "github.copilot.chat.edits.temporalContext.enabled": true,
  "github.copilot.chat.generateTests.codeLens": true,
  "github.copilot.chat.languageContext.fix.typescript.enabled": true,
  "github.copilot.chat.languageContext.inline.typescript.enabled": true,
  "github.copilot.chat.languageContext.typescript.enabled": true,
  "extensions.ignoreRecommendations": true,

  "xml.server.preferBinary": true,
  "workbench.hover.delay": 500,
  "window.zoomPerWindow": false,
  "workbench.tree.indent": 16,
  "explorer.compactFolders": false,
  "editor.fontSize": 14,
  "editor.lineNumbers": "relative",
  "editor.lineHeight": 1.2,
  "claudeCode.preferredLocation": "panel",
  "geminicodeassist.project": "general-483220",

  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "geminicodeassist.displayInlineContextHint": false,

  "search.exclude": {
    "**/node_modules": true,
    "**/vendor": true,
    "**/.git": true,
    "**/dist": true,
    "**/build": true,
  },

  "breadcrumbs.enabled": true,
  "breadcrumbs.symbolPath": "on",

  "svelte.plugin.svelte.format.config.svelteStrictMode": true,
  "php.suggest.basic": false,
  "intelephense.format.braces": "k&r",
  "workbench.activityBar.location": "top",
  "claudeCode.selectedModel": "opus",
  "terminal.integrated.fontWeight": "bold",
  "terminal.integrated.gpuAcceleration": "on",

  "outline.collapseItems": "alwaysCollapse",
  "github.copilot.selectedCompletionModel": "",

  "chat.editor.lineHeight": 1,
  "editor.minimap.showSlider": "always",
  "window.commandCenter": false,
  "markdown.preview.fontSize": 18,
  "settingsSync.ignoredExtensions": [
    "ms-vscode-remote.remote-wsl"
  ],
}