[user]
    name = Stan Runge
    email = stan@stanrunge.dev
    signingkey = 

[core]
    editor = nvim
    autocrlf = input
    ignorecase = false

[init]
    defaultBranch = main

[pull]
    rebase = false

[push]
    default = simple

[color]
    ui = auto

[alias]
    st = status
    co = checkout
    br = branch
    cm = commit
    lg = log --graph --pretty=format:'%C(yellow)%h%Creset -%C(cyan)%d%Creset %s %C(green)(%cr)%Creset %C(blue)<%an>%Creset' --abbrev-commit
    amend = commit --amend --no-edit
    fix = commit --amend
    undo = reset --soft HEAD~1

[diff]
    colorMoved = default

[credential]
    helper = store

[rerere]
    enabled = true

[merge]
    conflictstyle = zdiff3
    ff = only

[commit]
    gpgsign = false
